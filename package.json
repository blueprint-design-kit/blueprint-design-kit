{
  "name": "blueprint-design-kit",
  "version": "0.2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blueprint-design-kit/blueprint-design-kit.git"
  },
  "bin": {
    "blueprint": "blueprint.js"
  },
  "exports": {
    ".": {
      "import": "./dist/Blueprint/Blueprint.js",
      "require": "./dist/Blueprint/Blueprint.js",
      "types": "./src/types/index.ts"
    },
    "./fileManager": "./dist/fileManager/fileManager.js",
    "./types": "./src/types/index.ts"
  },
  "files": [
    "dist",
    "src",
    "blueprint.js"
  ],
  "scripts": {
    "dev": "npx tsc --watch",
    "build": "npx tsc",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@types/react": "^19.2.7",
    "deep-extend": "^0.6.0",
    "minimatch": "^10.2.0",
    "node-watch": "^0.7.4",
    "recursive-readdir": "^2.2.3"
  },
  "devDependencies": {
    "@types/deep-extend": "^0.6.2",
    "@types/node": "^25.2.3",
    "@types/recursive-readdir": "^2.2.4",
    "globals": "^17.3.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
