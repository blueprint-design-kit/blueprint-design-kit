{
  "name": "blueprint-design-kit",
  "version": "0.8.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blueprint-design-kit/blueprint-design-kit.git"
  },
  "keywords": [
    "blueprint",
    "storybook",
    "components",
    "component library",
    "ui testing",
    "visual regression"
  ],
  "type": "module",
  "bin": {
    "blueprint": "blueprint.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./ui": "./dist/ui/index.js"
  },
  "files": [
    "css",
    "dist",
    "src",
    "blueprint.js"
  ],
  "scripts": {
    "dev": "npx tsc --watch",
    "dev:local": "npx tsc && node put-files",
    "build": "rm -rf dist && npx tsc",
    "lint": "eslint",
    "test": "npm run build && vitest run",
    "test:unit": "vitest run --project unit",
    "test:browser": "vitest run --project browser",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@markedjs/html-differ": "^5.0.4",
    "color-name": "^2.1.0",
    "deep-extend": "^0.6.0",
    "html-react-parser": "^6.0.1",
    "json5": "^2.2.3",
    "minimatch": "^10.2.5",
    "node-watch": "^0.7.4",
    "playwright": "^1.59.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-element-to-jsx-string": "^17.0.1",
    "react-transition-group": "^4.4.5",
    "recursive-readdir": "^2.2.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/color-name": "^2.0.0",
    "@types/deep-extend": "^0.6.2",
    "@types/node": "^25.6.0",
    "@types/react-dom": "^19.2.3",
    "@types/react-transition-group": "^4.4.12",
    "@types/recursive-readdir": "^2.2.4",
    "@vitest/browser": "^4.1.4",
    "@vitest/browser-playwright": "^4.1.4",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.4",
    "vitest-browser-react": "^2.2.0"
  },
  "engines": {
    "node": ">=20.11.0"
  }
}
